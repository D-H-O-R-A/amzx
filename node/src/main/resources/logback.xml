<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">
    <property name="default.pattern" value="%date %-5level [%.25thread] %logger{26} - %msg%n"/>

    <logger name="io.grpc.netty" level="ERROR"/>
    <logger name="io.netty" level="INFO"/>
    <logger name="io.netty.channel.DefaultChannelPipeline" level="TRACE"/>

    <logger name="kamon.influxdb.InfluxDBReporter" level="INFO"/>
    <logger name="org.asynchttpclient" level="INFO"/>
    <logger name="oshi.hardware.platform.linux.LinuxDisks" level="INFO"/>

    <logger name="sun.rmi" level="INFO"/>
    <logger name="javax.management" level="INFO"/>

    <logger name="com.wavesplatform.utx.UtxPoolImpl.trace" level="OFF"/>
    <logger name="com.wavesplatform.network.PeerSynchronizer" level="DEBUG"/>
    <logger name="com.wavesplatform.transaction.smart" level="INFO"/>

    <logger name="scorex.crypto.signatures.Curve25519" level="INFO"/>

    <root level="TRACE"/>

    <property name="logback.file.enabled" value="false"/>

    <condition class="ch.qos.logback.core.boolex.IsPropertyDefinedCondition">
        <key>waves.directory</key>
    </condition>
    <if>
        <then>
            <property name="logback.file.enabled" value="true"/>
            <property name="logback.file.final-directory" value="${waves.directory}/log"/>
        </then>
    </if>

    <condition class="ch.qos.logback.core.boolex.IsPropertyDefinedCondition">
        <key>logback.file.directory</key>
    </condition>
    <if>
        <then>
            <property name="logback.file.enabled" value="true"/>
            <property name="logback.file.final-directory" value="${logback.file.directory}"/>
        </then>
    </if>

    <property name="logback.stdout.enabled" value="true"/>
    <property name="logback.utx-trace.enabled" value="false"/>

    <include optional="true" file="${waves.config.directory:-.}/logback.xml"/>

    <condition class="ch.qos.logback.core.boolex.PropertyEqualityCondition">
        <key>logback.stdout.enabled</key>
        <value>true</value>
    </condition>
    <if>
        <then>
            <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
                <target>System.out</target>
                <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                    <level>${logback.stdout.level:-INFO}</level>
                </filter>
                <encoder>
                    <pattern>${logback.pattern:-${default.pattern}}</pattern>
                </encoder>
            </appender>
            <root>
                <appender-ref ref="STDOUT"/>
            </root>
        </then>
    </if>

    <condition class="ch.qos.logback.core.boolex.PropertyEqualityCondition">
        <key>logback.file.enabled</key>
        <value>true</value>
    </condition>
    <if>
        <then>
            <property name="appender.name" value="FILE"/>
            <property name="appender.file" value="waves"/>
            <property name="appender.level" value="${logback.file.level}"/>

            <include resource="file-appender-template.xml"/>

            <root>
                <appender-ref ref="FILE"/>
            </root>
        </then>
    </if>

    <condition class="ch.qos.logback.core.boolex.PropertyEqualityCondition">
        <key>logback.utx-trace.enabled</key>
        <value>true</value>
    </condition>
    <if>
        <then>
            <property name="appender.name" value="UTX-TRACE"/>
            <property name="appender.file" value="utx-trace"/>
            <property name="appender.level" value="TRACE"/>

            <include resource="file-appender-template.xml"/>

            <logger name="com.wavesplatform.utx.UtxPoolImpl.trace" additivity="false" level="TRACE">
                <appender-ref ref="UTX-TRACE"/>
            </logger>
        </then>
    </if>
</configuration>
